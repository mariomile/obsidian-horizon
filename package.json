{
  "name": "horizon",
  "version": "0.3.0",
  "description": "Calendar for your vault: daily and periodic notes, tasks, and dated notes in one place.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "pnpm typecheck && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --experimental-strip-types --test \"src/**/*.test.ts\""
  },
  "keywords": [
    "obsidian",
    "calendar",
    "daily-notes",
    "periodic-notes",
    "tasks"
  ],
  "author": "Mario Miletta",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "moment": "^2.30.1",
    "obsidian": "1.13.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
